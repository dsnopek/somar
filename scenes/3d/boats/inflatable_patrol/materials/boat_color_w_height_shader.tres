[gd_resource type="Shader" format=3 uid="uid://bufpt1ntjbbl4"]

[resource]
code = "shader_type spatial;

uniform vec3 albedo_color : source_color = vec3(1.0);
uniform sampler2D albedo_texture : source_color, filter_linear_mipmap, repeat_enable;
global uniform float water_surface_height;

varying vec3 world_vertex;


void vertex() {
	world_vertex = (MODEL_MATRIX * vec4(VERTEX, 1.0)).xyz;
}

void fragment() {
	vec4 albedo_t = texture(albedo_texture, UV);
	
	ALBEDO = albedo_color * albedo_t.rgb;
	ALPHA = 1.0 * (water_surface_height - world_vertex.y);
	ALPHA_SCISSOR_THRESHOLD = 0.0;
}
"
