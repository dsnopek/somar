[node name="HBoxContainer4" type="HBoxContainer" parent="VBoxContainer/ContentContainer/VBoxContainer"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="Label" type="Label" parent="VBoxContainer/ContentContainer/VBoxContainer/HBoxContainer4"]
layout_mode = 2
text = "Depth variation:"

[node name="MinDepthVariationSpinBox" type="SpinBox" parent="VBoxContainer/ContentContainer/VBoxContainer/HBoxContainer4"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
tooltip_text = "Minimum depth variation. The depth variation is the vertical offset from the spawn height. For example, if the entity spawns at a height of 3 meters, and the minimum depth variation is -1, then the entity is allowed to go to 2 meters as well as 3. Default: -1"
min_value = -10.0
max_value = -0.5
step = 0.1
value = -1.0
suffix = "(lower)"

[node name="MaxDepthVariationSpinBox" type="SpinBox" parent="VBoxContainer/ContentContainer/VBoxContainer/HBoxContainer4"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
tooltip_text = "Maximum depth variation. The depth variation is the vertical offset from the spawn height. For example, if the entity spawns at a height of 2 meters, and the maximum depth variation is 2, then the entity is allowed to go to 4 meters as well as 2. Default: 1"
min_value = 0.5
max_value = 10.0
step = 0.1
value = 1.0
suffix = "(upper)"

[node name="HBoxContainer5" type="HBoxContainer" parent="VBoxContainer/ContentContainer/VBoxContainer"]
layout_mode = 2
theme_override_constants/separation = 16

