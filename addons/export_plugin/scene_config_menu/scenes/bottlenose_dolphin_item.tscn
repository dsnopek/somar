unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
tooltip_text = "The breathing time controls how often the entity needs to swim to the surface to breathe. This may vary by a few seconds, since it can only surface when it completes half a rotation around the player. Default: 60"
min_value = 1.0
max_value = 1000.0
step = 0.1
value = 60.0
suffix = "seconds"

[node name="HBoxContainer2" type="HBoxContainer" parent="VBoxContainer/ContentContainer/VBoxContainer/HBoxContainer5"]
layout_mode = 2
tooltip_text = "The initial spawn direction of the entity. For example, a spawn direction of x: 0 and z: -1 will spawn the dolphin right in front of the player.
Leave as x: 0 and z: 0 to choose a random spawn direction."
theme_override_constants/separation = 8

